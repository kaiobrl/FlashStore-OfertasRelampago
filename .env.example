# FlashStore Production Environment Variables
# Rename this file to .env and fill in the values

# VAPID Public Key for Push Notifications
# Generate one at: https://web-push-codelab.glitch.me/
VITE_VAPID_PUBLIC_KEY=your_base64_public_key_here

# API Base URL (if you implement a backend later)
VITE_API_URL=https://api.flashstore.com

# Analytics ID (Google Analytics, etc.)
VITE_ANALYTICS_ID=G-XXXXXXXXXX
